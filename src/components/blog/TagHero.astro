---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<section
  class="px-10 pt-16 pb-14"
  style="border-color: color-mix(in srgb, var(--color-websylvain-pierre) 50%, transparent);"
>
  <div class="container mx-auto">
    <span class="section-label">Tag</span>
    
    <h1 class="text-display mt-4 mb-5" style="color: var(--color-websylvain-encre);">
      <span style="color: var(--color-websylvain-argile);">#</span>{tag}
    </h1>
    
    <p
      class="text-md leading-loose"
      style="color: var(--color-websylvain-schiste);"
    >
      Tous les articles étiquetés avec ce tag.
    </p>
    
    <div class="mt-6">
      <a href="/blog" class="btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Retour au blog
      </a>
    </div>
  </div>
</section>