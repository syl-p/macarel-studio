---
const timeline = [
  {
    period: 'Depuis toujours',
    title: 'Dev par vocation',
    body: "Pas de reconversion, pas de bootcamp de 3 mois. Le code depuis le début — d'abord par curiosité, puis par métier, toujours par plaisir.",
    color: '#C84B11',
  },
  {
    period: '10 ans de pratique',
    title: 'L\'artisanat avant tout',
    body: "Une décennie à affiner la même conviction : un bon outil se juge à ce qu'il permet, pas à la complexité de ce qu'il cache dessous.",
    color: '#F2A122',
  },
  {
    period: "Aujourd'hui",
    title: 'WebSylvain',
    body: "Indépendant à Carcassonne, je travaille avec des PME, des startups et des agences qui ont besoin d'un développeur impliqué — pas d'un prestataire qui livre et disparaît.",
    color: '#2D6A4F',
  },
]
---
 
<section class="section py-14">
  <div class="container mx-auto">
    <span class="section-label">Le parcours</span>
    <h2 class="section-h2 mt-1 mb-10">Comment j'en suis arrivé là.</h2>
    
    <div class="flex flex-col gap-0">
        {timeline.map((item, i) => (
        <div class="grid gap-6 py-8 border-b border-thin sm:grid-cols-[160px_1fr]"
            style="border-color: color-mix(in srgb, var(--color-websylvain-pierre) 40%, transparent);"
        >
            <!-- Période -->
            <div class="flex items-center gap-3 sm:flex-col sm:gap-2">
              <div
                  class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0"
                  style={`background-color: ${item.color};`}
              ></div>
              <span
                  class="text-sm font-medium"
                  style="color: var(--color-websylvain-schiste);"
              >
                  {item.period}
              </span>
            </div>

            <!-- Contenu -->
            <div>
              <h3
                  class="text-base font-medium mb-2"
                  style="color: var(--color-websylvain-encre);"
              >
                  {item.title}
              </h3>
              <p
                  class="text-sm leading-loose"
                  style="color: var(--color-websylvain-schiste);"
              >
                  {item.body}
              </p>
            </div>
        </div>
        ))}
    </div>
  </div>
</section>