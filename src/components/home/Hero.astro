---
import Avatar from './Avatar.astro'
// Pas de props pour l'instant — contenu statique
---

<section class="hero-dark py-14 px-7 border-b border-thin border-macarel-garrigue/30">
  <div class="container mx-auto">
    <!-- Disponibilité -->
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5"
      style="background-color: rgba(45,106,79,0.15);
              border: 0.5px solid rgba(45,106,79,0.3);"
    >
      <span
        class="w-2 h-2 rounded-full flex-shrink-0 animate-pulse"
        style="background-color: #2D6A4F;
                box-shadow: 0 0 0 2px rgba(45,106,79,0.25);"
      ></span>
      <span
        class="text-sm font-medium"
        style="color: #2D6A4F; letter-spacing: 0.04em;"
      >
        Disponible pour de nouveaux projets
      </span>
    </div>

    <!-- H1 + Avatar -->
    <div class="flex align-middle items-center gap-4 mb-5">
      <Avatar size="xl" src="/img/avatar.jpg" />

      <h1 class="text-display text-macarel-calcaire max-w-prose">
        Sylvain Pastor<br>
        Développeur web
        <em class="not-italic text-macarel-soleil">
         Freelance.
        </em>
      </h1>
    </div>

    <!-- Corps -->
    <p class="text-macarel-miel/80 leading-loose mb-7">
      Je conçois des outils métier sur mesure, des SaaS et des plateformes web avec Rails et Hotwire. <br>
      Un <u>collaborateur</u> pour les PME et startups qui veulent un développeur impliqué, pas un prestataire qui livre et disparaît.
    </p>

    <!-- CTAs -->
    <div class="flex gap-2.5 flex-wrap mb-7">
      <a href="/contact" class="btn-primary">
        Parler du projet
      </a>
      <a href="/projets" class="btn-secondary-dark">
        Voir les réalisations
      </a>
    </div>
  </div>
</section>