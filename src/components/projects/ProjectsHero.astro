---
interface Props {
  count: number
}
const { count } = Astro.props
---

<section
  class="px-10 pt-16 pb-14 border-b border-thin"
  style="border-color: color-mix(in srgb, var(--color-macarel-pierre) 50%, transparent);"
>
  <div class="container mx-auto">
    <span class="section-label">Projets</span>

    <h1 class="text-display mt-4 mb-5" style="color: var(--color-macarel-encre);">
      Découvrez mes
      <em class="not-italic" style="color: var(--color-macarel-argile);">
        projets.
      </em>
    </h1>

    <p class="text-md leading-loose max-w-content" style="color: var(--color-macarel-schiste);">
      {count > 0
        ? `${count} projet${count > 1 ? 's' : ''} présenté${count > 1 ? 's' : ''} — des réalisations représentatives de mon travail.`
        : "Des projets bientôt documentés ici. En attendant, contactez-moi directement pour en discuter."
      }
    </p>
  </div>
</section>
