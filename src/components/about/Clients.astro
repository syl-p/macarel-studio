---
const clients = [
  {
    color: '#FEF3E2',
    iconColor: '#C84B11',
    title: 'PME & ETI',
    body: "Vous avez besoin d'un outil métier qui remplace un process manuel ou un outil générique qui ne colle plus à votre réalité. On construit exactement ce dont vous avez besoin.",
    icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <rect x="1" y="1" width="14" height="14" rx="2" stroke="#C84B11" stroke-width="1.2"/>
      <path d="M4 5h8M4 8h5M4 11h6" stroke="#C84B11" stroke-width="1.1" stroke-linecap="round"/>
    </svg>`,
  },
  {
    color: '#E8F5EE',
    iconColor: '#2D6A4F',
    title: 'Startups & fondateurs',
    body: "Vous avez une idée de SaaS. On la construit avec la bonne architecture dès le départ — pas de dette technique dès la v1, pas de refonte dans 6 mois.",
    icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M2 13L8 3l6 10" fill="none" stroke="#2D6A4F" stroke-width="1.4" stroke-linejoin="round"/>
      <path d="M5 9h6" stroke="#2D6A4F" stroke-width="1.4" stroke-linecap="round"/>
    </svg>`,
  },
  {
    color: '#FEF3E2',
    iconColor: '#C84B11',
    title: 'Agences design',
    body: "Vous concevez, je développe. Je suis le bras technique que les agences créatives cherchent pour leurs clients — Rails et Hotwire pour des interfaces pixel-perfect sans surcharge.",
    icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <rect x="2" y="2" width="5" height="5" rx="1" stroke="#C84B11" stroke-width="1.2"/>
      <rect x="9" y="2" width="5" height="5" rx="1" stroke="#C84B11" stroke-width="1.2"/>
      <rect x="2" y="9" width="5" height="5" rx="1" stroke="#C84B11" stroke-width="1.2"/>
      <rect x="9" y="9" width="5" height="5" rx="1" stroke="#C84B11" stroke-width="1.2"/>
    </svg>`,
  },
  {
    color: '#E8F5EE',
    iconColor: '#2D6A4F',
    title: 'Équipes en croissance',
    body: "Votre app Rails ne tient plus la charge, ou votre codebase est devenue difficile à faire évoluer. J'audite, je refactorise, je mets en place les bonnes pratiques.",
    icon: `<svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M3 8h2l2-4 2 8 2-5 1 1h1"
            stroke="#2D6A4F" stroke-width="1.2"
            stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>`,
  },
]
---
 
<section class="section">
    <div class="container mx-auto">
        <span class="section-label">Je travaille avec</span>
        
        <div class="grid grid-cols-1 gap-2 mt-4 sm:grid-cols-2">
            {clients.map((c) => (
            <div class="card">
                <div
                class="w-7 h-7 rounded-md flex items-center justify-center mb-3"
                style={`background-color: ${c.color};`}
                >
                <Fragment set:html={c.icon} />
                </div>
                <h3 class="text-base font-medium mb-1.5"
                    style="color: var(--color-websylvain-encre);">
                {c.title}
                </h3>
                <p class="text-sm leading-relaxed"
                style="color: var(--color-websylvain-schiste);">
                {c.body}
                </p>
            </div>
            ))}
        </div>
    </div>
</section>