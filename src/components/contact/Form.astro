<div
  class="px-10 py-12 border-r border-thin shadow-lg bg-white"
  style="border-color: color-mix(in srgb, var(--color-websylvain-pierre) 50%, transparent);"
>
  <h2 class="text-xl font-medium mb-8" style="color: var(--color-websylvain-encre);">
    Parlez-moi de votre projet
  </h2>
 
  <form
    method="POST"
    action="/api/contact"
    class="flex flex-col gap-6"
    id="contact-form"
  >
    <!-- Nom + Email sur la même ligne -->
    <div class="grid grid-cols-2 gap-4">
      <div class="form-field">
        <label for="name" class="form-label">Votre nom</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jean Dupont"
          class="form-input"
          autocomplete="name"
        />
      </div>
      <div class="form-field">
        <label for="email" class="form-label">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jean@entreprise.fr"
          class="form-input"
          autocomplete="email"
        />
      </div>
    </div>
 
    <!-- Société -->
    <div class="form-field">
      <label for="company" class="form-label">
        Société
        <span class="form-label-optional">— optionnel</span>
      </label>
      <input
        type="text"
        id="company"
        name="company"
        placeholder="Mon Entreprise SAS"
        class="form-input"
        autocomplete="organization"
      />
    </div>
 
    <!-- Type de projet + Budget sur la même ligne -->
    <div class="grid grid-cols-2 gap-4">
      <div class="form-field">
        <label for="project_type" class="form-label">Type de projet</label>
        <select id="project_type" name="project_type" class="form-select" required>
          <option value="" disabled selected>Choisissez...</option>
          <option value="outil_metier">Outil métier sur mesure</option>
          <option value="saas">SaaS / produit web</option>
          <option value="accompagnement">Accompagnement technique A à Z</option>
          <option value="autre">Autre / je ne sais pas encore</option>
        </select>
      </div>
      <div class="form-field">
        <label for="budget" class="form-label">
          Budget
          <span class="form-label-optional">— optionnel</span>
        </label>
        <select id="budget" name="budget" class="form-select">
          <option value="" disabled selected>Fourchette...</option>
          <option value="lt5k">Moins de 5 000 €</option>
          <option value="5k10k">5 000 — 10 000 €</option>
          <option value="10k25k">10 000 — 25 000 €</option>
          <option value="gt25k">Plus de 25 000 €</option>
          <option value="nsp">Je ne sais pas encore</option>
        </select>
      </div>
    </div>
 
    <!-- Message -->
    <div class="form-field">
      <label for="message" class="form-label">Décrivez votre projet</label>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        placeholder="Donnez-moi le contexte — votre métier, le problème à résoudre, l'état d'avancement. Même une idée brute, c'est un bon point de départ."
        class="form-input form-textarea"
      ></textarea>
    </div>
 
    <!-- Honeypot anti-spam -->
    <div class="hidden" aria-hidden="true">
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
    </div>
 
    <!-- Submit -->
    <div class="flex flex-col gap-4 mt-2">
      <button type="submit" class="btn-primary w-fit">
        Envoyer le message
      </button>
 
      <!-- États feedback -->
      <div id="form-success" class="hidden">
        <div
          class="flex items-start gap-3 p-4 rounded-lg"
          style="background-color: var(--color-websylvain-thym-lt);"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 flex-shrink-0">
            <circle cx="8" cy="8" r="6" stroke="#2D6A4F" stroke-width="1.2"/>
            <path d="M5.5 8l1.5 1.5L10.5 6" stroke="#2D6A4F" stroke-width="1.2"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p class="text-sm" style="color: var(--color-websylvain-thym);">
            Message envoyé — je reviens vers vous sous 48h.
          </p>
        </div>
      </div>
 
      <div id="form-error" class="hidden">
        <p class="text-sm" style="color: var(--color-websylvain-argile);">
          Une erreur est survenue. Écrivez-moi directement à
          <a href="mailto:contact@websylvain.com" class="font-medium">
            contact@websylvain.com
          </a>.
        </p>
      </div>
    </div>
 
  </form>
</div>
 
<script>
  const form    = document.getElementById('contact-form')    as HTMLFormElement | null
  const success = document.getElementById('form-success')
  const error   = document.getElementById('form-error')
 
  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form || !success || !error) return
 
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    btn.disabled    = true
    btn.textContent = 'Envoi en cours...'
 
    try {
      const res = await fetch(form.action, {
        method:  'POST',
        body:    new FormData(form),
        headers: { 'Accept': 'application/json' },
      })
 
      if (res.ok) {
        form.reset()
        success.classList.remove('hidden')
        error.classList.add('hidden')
      } else {
        throw new Error('Server error')
      }
    } catch {
      error.classList.remove('hidden')
      success.classList.add('hidden')
      btn.disabled    = false
      btn.textContent = 'Envoyer le message'
    }
  })
</script>