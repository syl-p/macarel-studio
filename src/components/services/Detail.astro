---
  const { service } = Astro.props
---
 
<section
  id={service.frontmatter.id}
  class="px-10 py-14 border-b border-thin scroll-mt-20"
  style="border-color: color-mix(in srgb, var(--color-websylvain-pierre) 50%, transparent);"
>
  <div class="container mx-auto grid grid-cols-1 gap-12 sm:grid-cols-2 sm:items-start">
 
    <!-- Colonne gauche — titre + description -->
    <div>
 
      <!-- En-tête -->
      <div class="flex items-center gap-3 mb-5">
        <div
          class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
          style={`background-color: ${service.frontmatter.iconBg};`}
        >
          <Fragment set:html={service.frontmatter.icon} />
        </div>
        <div>
          <span
            class="text-xs font-medium font-mono block mb-0.5"
            style="color: var(--color-websylvain-schiste);"
          >
            {service.frontmatter.number} /
          </span>
          <span class={service.frontmatter.badgeClass}>{service.frontmatter.badge}</span>
        </div>
      </div>
 
      <!-- Titre -->
      <h2
        class="text-3xl font-medium tracking-tight leading-tight mb-2"
        style="color: var(--color-websylvain-encre);"
      >
        {service.frontmatter.title}
      </h2>
 
      <!-- Baseline -->
      <p class="text-md font-medium mb-6" style={`color: ${service.frontmatter.accent};`}>
        {service.frontmatter.baseline}
      </p>
 
      <!-- Description -->
      <p class="text-base leading-loose" style="color: var(--color-websylvain-schiste);">
        {service.frontmatter.description}
      </p>
 
    </div>
 
    <!-- Colonne droite — points clés + CTA -->
    <div class="flex flex-col gap-8 sm:pt-2">
 
      <!-- Points clés -->
      <div>
        <span class="text-label" style="display: block; margin-bottom: 14px;">
          Ce que ça couvre
        </span>
        <div class="flex flex-col gap-2.5">
          {service.frontmatter.points.map((point) => (
            <div class="fact-item">
              <span
                class="fact-dot"
                style={`background-color: ${service.frontmatter.accent};`}
              ></span>
              <span>{point}</span>
            </div>
          ))}
        </div>
      </div>
     </div>
  </div>
</section>