---
import Differentiator from './Differentiator.astro';

const differentiators = [
  {
    title: 'Hypermedia par conviction',
    body: "Rails + Hotwire — pas par défaut, par choix. Interfaces réactives sans les complexités d'une SPA.",
    color: '#C84B11',
  },
  {
    title: 'Un interlocuteur, pas une équipe',
    body: "Vous parlez directement au développeur qui code. La décision du matin est dans le code l'après-midi.",
    color: '#F2A122',
  },
  {
    title: 'Livraison continue',
    body: "Itérations courtes, démos régulières. Vous voyez le produit se construire.",
    color: '#2D6A4F',
  },
  {
    title: 'Autonomie à la livraison',
    body: "Code documenté, CI/CD en place. L'outil vous appartient.",
    color: '#C84B11',
  },
]
---

<section
  class="px-10 py-12"
  style="background-color: var(--color-websylvain-craft);"
>
  <div class="container mx-auto">
    <span class="section-label" style="color: var(--color-websylvain-garrigue); opacity: 0.7;">
        Pourquoi WebSylvain
    </span>
    <h2 class="section-h2 mt-1 mb-8">Ce qui fait la différence.</h2>
    
    <div class="max-w-wide grid grid-cols-1 sm:grid-cols-2 gap-6">
        {differentiators.map((d) => (
        <Differentiator title={d.title} body={d.body} color={d.color} />
        ))}
    </div>
  </div>
</section>