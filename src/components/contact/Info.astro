---
// Pas de props
---
 
<div class="px-7 py-9 flex flex-col gap-8">
 
  <!-- Disponibilité -->
  <div>
    <h2 class="text-xl font-medium mb-4" style="color: var(--color-macarel-encre);">
      Avant d'écrire
    </h2>
 
    <div class="flex flex-col gap-2">
 
      <div class="fact-item">
        <span class="fact-dot"></span>
        <span>
          <strong class="font-medium" style="color: var(--color-macarel-encre);">
            Premier échange gratuit
          </strong>
          — on cadre ensemble votre besoin, sans engagement.
        </span>
      </div>
 
      <div class="fact-item">
        <span class="fact-dot"></span>
        <span>
          <strong class="font-medium" style="color: var(--color-macarel-encre);">
            Réponse sous 48h
          </strong>
          — en semaine. Souvent moins.
        </span>
      </div>
 
      <div class="fact-item">
        <span class="fact-dot"></span>
        <span>
          <strong class="font-medium" style="color: var(--color-macarel-encre);">
            Pas de spec nécessaire
          </strong>
          — une idée brute suffit pour démarrer la conversation.
        </span>
      </div>
 
      <div class="fact-item">
        <span class="fact-dot"></span>
        <span>
          <strong class="font-medium" style="color: var(--color-macarel-encre);">
            Basé à Carcassonne
          </strong>
          — intervention sur toute la France en remote.
          Déplacement possible sur Occitanie.
        </span>
      </div>
 
    </div>
  </div>
 
  <!-- Contact direct -->
  <div>
    <h3 class="text-label mb-3">Contact direct</h3>
    <div class="flex flex-col gap-2">
 
      <a
        href="mailto:hello@macarel.studio"
        class="craft-stack-item group no-underline"
        style="text-decoration: none;"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             style="color: var(--color-macarel-argile); flex-shrink: 0;">
          <rect x="1" y="3" width="14" height="10" rx="2"
                stroke="currentColor" stroke-width="1.2"/>
          <path d="M1 5l7 5 7-5" stroke="currentColor"
                stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span class="craft-stack-name text-sm">hello@macarel.studio</span>
      </a>
 
      <a
        href="https://github.com/macarel-studio"
        target="_blank"
        rel="noopener noreferrer"
        class="craft-stack-item no-underline"
        style="text-decoration: none;"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             style="color: var(--color-macarel-schiste); flex-shrink: 0;">
          <path d="M8 1C4.13 1 1 4.13 1 8c0 3.09 2 5.72 4.79 6.65.35.06.48-.15.48-.34v-1.2c-1.95.42-2.36-.94-2.36-.94-.32-.81-.78-1.03-.78-1.03-.64-.43.05-.42.05-.42.7.05 1.07.72 1.07.72.62 1.07 1.63.76 2.03.58.06-.45.24-.76.44-.93-1.56-.18-3.2-.78-3.2-3.47 0-.77.27-1.39.72-1.88-.07-.18-.31-.89.07-1.85 0 0 .59-.19 1.93.72A6.7 6.7 0 018 4.84c.6 0 1.2.08 1.76.23 1.34-.9 1.93-.72 1.93-.72.38.96.14 1.67.07 1.85.45.49.72 1.11.72 1.88 0 2.7-1.64 3.29-3.21 3.46.25.22.48.65.48 1.31v1.95c0 .19.13.4.48.33C13 13.72 15 11.09 15 8c0-3.87-3.13-7-7-7z"
                fill="currentColor"/>
        </svg>
        <span class="craft-stack-name text-sm">GitHub</span>
      </a>
 
      <a
        href="https://linkedin.com/in/macarel-studio"
        target="_blank"
        rel="noopener noreferrer"
        class="craft-stack-item no-underline"
        style="text-decoration: none;"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
             style="color: var(--color-macarel-schiste); flex-shrink: 0;">
          <rect x="1" y="1" width="14" height="14" rx="2"
                stroke="currentColor" stroke-width="1.2"/>
          <path d="M4 6.5V12M4 4v.5" stroke="currentColor"
                stroke-width="1.4" stroke-linecap="round"/>
          <path d="M8 12V9c0-1.1.9-2 2-2s2 .9 2 2v3M8 6.5V12"
                stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <span class="craft-stack-name text-sm">LinkedIn</span>
      </a>
 
    </div>
  </div>
 
  <!-- Disponibilité actuelle -->
  <div class="p-4 rounded-xl border-thin"
    style="background-color: var(--color-macarel-craft);
           border-color: var(--color-macarel-pierre);">
    <div class="flex items-center gap-2 mb-1.5">
      <span class="w-2 h-2 rounded-full"
            style="background-color: #2D6A4F;
                   box-shadow: 0 0 0 3px color-mix(in srgb, #2D6A4F 20%, transparent);">
      </span>
      <span class="text-xs font-medium" style="color: #2D6A4F;">
        Disponible pour de nouveaux projets
      </span>
    </div>
    <p class="text-xs leading-relaxed" style="color: var(--color-macarel-schiste);">
      Démarrage possible dès ce mois. Les projets sont pris en charge un par un
      — pour garder le niveau d'attention que vous méritez.
    </p>
  </div>
 
</div>